# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# FONNTE_API_KEY: Required for WhatsApp notifications.
FONNTE_API_KEY="MY_FONNTE_API_KEY"

# SUPABASE_ACCESS_TOKEN: Required to deploy Edge Functions from this environment.
# Get it from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# SUPABASE_PROJECT_ID: The reference ID of your Supabase project.
# Example: zijddnkpfadirqwtxmmk
SUPABASE_PROJECT_ID=

# SUPABASE_URL: Your Supabase project URL.
# Example: https://zijddnkpfadirqwtxmmk.supabase.co
SUPABASE_URL=

# SUPABASE_SERVICE_ROLE_KEY: Your Supabase service role key.
SUPABASE_SERVICE_ROLE_KEY=
